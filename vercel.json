{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/check-letters",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/consolidate-memory",
      "schedule": "0 3 * * *"
    }
  ]
}
